## App
APP_PORT=3004
REQUEST_BODY_LIMIT="64kb"
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Token and Secret
JWT_SECRET=""
BROWSER_EXTENSION_SECRET=""
JWT_TOKEN_EXPIRY_TIME="3h"


## Mistral AI
