NODE_ENV=production

# Railway injects PORT. APP_PORT is only needed for local production tests.
APP_PORT=3004
REQUEST_BODY_LIMIT=64kb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Must match Succeed AI/Config.swift apiKey in the signed macOS build.
JWT_SECRET=

# Optional secondary token for browser-extension or internal clients.
BROWSER_EXTENSION_SECRET=
JWT_TOKEN_EXPIRY_TIME=3h

# Default production provider.
OPENAI_API_ENABLED=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
OPENAI_MAX_OUTPUT_TOKENS=1200
OPENAI_TIMEOUT_MS=45000

# Keep disabled unless Railway has the corresponding provider keys.
MISTRAL_AI_API_ENABLED=false
MISTRAL_AI_API_KEY=
MISTRAL_AI_MODEL=mistral-large-latest

CLAUDE_AI_API_ENABLED=false
CLAUDE_AI_API_KEY=
CLAUDE_AI_MODEL=claude-3-5-sonnet-latest

LLAMA_API_ENABLED=false
LLAMA_API_KEY=
LLAMA_MODEL=
LLAMA_MAX_COMPLETION_TOKENS=1200
LLAMA_TIMEOUT_MS=45000

# Enable only after Lemon Squeezy license keys are available in the macOS app.
LICENSE_CHECK_ENABLED=false
LEMON_SQUEEZY_API_KEY=
